# ── Copy this to .env and fill in real values ──────────────────────────────

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Kalshi RSA auth — leave blank for anonymous read-only access to sandbox
# Production API: https://api.elections.kalshi.com/trade-api/v2 (all sports)
# Demo API:       https://demo-api.kalshi.co/trade-api/v2        (sandbox only)
KALSHI_KEY_ID=your-kalshi-key-id
KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Optional — NewsAPI.org key (falls back to Google News RSS if omitted)
NEWS_API_KEY=

# Optional — The Odds API key (https://the-odds-api.com)
# Free tier: 500 req/month — sufficient at 2 scans/day × 4 sports
# Without this key the bot still works; it falls back to AI-only edge calculation
ODDS_API_KEY=

# Trading — live config (sized for $10 live bankroll)
PAPER_TRADING=false
INITIAL_BANKROLL=10.0
KELLY_FRACTION=0.25
MAX_TRADE_PCT=0.10
MAX_TRADE_USD=11.0
MIN_CONFIDENCE=0.55
MIN_EDGE_THRESHOLD=0.02
SCAN_INTERVAL_HOURS=2
MIN_MARKET_VOLUME=100.0
MAX_BID_ASK_SPREAD=0.04

# Sportsbook coverage gate — set to false to fall back to AI-only edge
REQUIRE_SPORTSBOOK_ODDS=true

# Sports to monitor (comma-separated)
MONITORED_SPORTS=["Cricket","NBA","NFL","MLS"]

# Database (override for external Postgres)
DATABASE_URL=postgresql+asyncpg://kalshi:kalshi@localhost:5432/kalshi_bot

# Debug
DEBUG=false
